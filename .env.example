# Bind 0.0.0.0 so phones on same Wi‑Fi can reach the API (see serve.py)
API_HOST=0.0.0.0
API_PORT=8000

GEMINI_API_KEY=your-gemini-api-key

# Stable Gemini 3.1 Flash — fast and cost-efficient (no thinking mode).
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_THINKING_ENABLED=false
GEMINI_THINKING_BUDGET=2048

GEMINI_ANALYZE_TEMPERATURE=0.0

MIN_IMAGES=1
MAX_IMAGES=10
MAX_IMAGE_SIZE_MB=15
MAX_PREPROCESS_EDGE_PX=2048

# Detail vs cost lever (low | medium | high). ultra_high is clamped to high by the SDK.
MEDIA_RESOLUTION_COLLAGE=high
MEDIA_RESOLUTION_MULTI=high

# Cost estimate pricing (USD per 1M tokens) — match your GEMINI_MODEL
GEMINI_INPUT_USD_PER_1M=0.25
GEMINI_OUTPUT_USD_PER_1M=1.50

# USD->INR. Production: FX_ENABLED=true (live rate, cached; falls back to USD_TO_INR_FALLBACK).
FX_ENABLED=true
FX_API_URL=https://api.frankfurter.dev/v1/latest
FX_CACHE_TTL_SECONDS=3600
FX_TIMEOUT_SECONDS=4.0
USD_TO_INR_FALLBACK=83.0

# Optional: path to valuation JSON (category baselines, depreciation, rules). Default: app/data/reference_prices.json
REFERENCE_PRICES_PATH=

RATE_LIMIT_PER_MINUTE=60
GEMINI_MAX_RETRIES=2
# GEMINI_HARD_TIMEOUT_SECONDS=0 means no asyncio cap on Gemini (default)
GEMINI_TIMEOUT_SECONDS=30
GEMINI_HARD_TIMEOUT_SECONDS=0

# ANALYSIS_TARGET_MS=0 disables slow-request warning threshold
ANALYSIS_TARGET_MS=0
MAX_IMAGES_LATENCY_MODE=6
VALUATION_CONFIDENCE_THRESHOLD=0.75
PROMPT_VERSION=v2

# India-first client defaults
DEFAULT_LOCALE=en-IN
MARKET_REGION=IN
DISPLAY_CURRENCY=INR

REVIEW_CONFIDENCE_THRESHOLD=0.65
FIELD_CONFIDENCE_THRESHOLD=0.5
